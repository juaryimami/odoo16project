<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="ir.module.category" id="module_category_construction">
            <field name="name">Construction ERP</field>
            <field name="description">Construction and Real Estate Management</field>
            <field name="sequence">15</field>
        </record>

        <record id="group_construction_supervisor" model="res.groups">
            <field name="name">Site Supervisor</field>
            <field name="category_id" ref="module_category_construction"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_construction_manager" model="res.groups">
            <field name="name">Construction Manager</field>
            <field name="category_id" ref="module_category_construction"/>
            <!-- Add project mapping inherit natively -->
            <field name="implied_ids" eval="[(4, ref('construction_erp.group_construction_supervisor')), (4, ref('project.group_project_manager'))]"/>
        </record>
        <record id="group_construction_sales" model="res.groups">
            <field name="name">Sales Team</field>
            <field name="category_id" ref="module_category_construction"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
