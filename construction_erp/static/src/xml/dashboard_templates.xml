<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="construction_erp.OwlDashboardNative" owl="1">
        <div class="ovl-dashboard-wrapper w-100 h-100 overlay-container" style="background-color: #f8f9fc;">
            <div t-if="state.is_loading" class="o_spinner p-5 text-center">
                <h2 style="color: #4e73df;"><i class="fa fa-circle-o-notch fa-spin"></i> Harvesting Strategic Intelligence...</h2>
            </div>
            
            <div t-else="" class="container-fluid p-0 d-flex flex-column" style="height: 100vh; overflow: hidden;">
                
                <div class="header-section p-4 pb-2">
                    <div class="d-flex align-items-center justify-content-between">
                        <h2 class="dashboard-header fw-bold text-dark m-0"><i class="fa fa-th-large text-primary"></i> Executive Intelligence Command</h2>
                        <div class="header-refresh cursor-pointer text-muted" t-on-click="loadMetrics">
                            <i class="fa fa-refresh"></i> Live Sync Active
                        </div>
                    </div>
                </div>

                <div class="row g-0 flex-grow-1 overflow-hidden">
                    <!-- Segmented Intelligence Sidebar -->
                    <div class="col-lg-3 dashboard-sidebar-column p-4 pt-2">
                        
                        
                        <!-- FINANCIAL AUDIT HUB -->
                        <div class="dashboard-sidebar-group">
                            <h6 class="sidebar-group-title">FINANCIAL AUDIT HUB</h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="metric-card metric-blue hover-lift cursor-pointer" t-on-click="openEstimates">
                                        <i class="fa fa-calculator card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.estimate_count or 0"/>
                                        <div class="card-label">Cost Sheets</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="metric-card metric-indigo hover-lift cursor-pointer" t-on-click="openProjects">
                                        <i class="fa fa-building card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.project_count or 0"/>
                                        <div class="card-label">Projects</div>
                                    </div>
                                </div>
                                <div class="col-12 mt-2">
                                    <div class="metric-card metric-gold p-4 hover-lift">
                                        <i class="fa fa-money card-icon"></i>
                                        <div class="d-flex align-items-center">
                                            <div class="text-start w-100">
                                                <div class="small fw-bold text-muted text-uppercase mb-2" style="font-size: 0.65rem; letter-spacing: 1px;">Realized Portfolio Sales</div>
                                                <h3 class="fw-bolder m-0 text-dark mb-2" style="font-size: 2.2rem; letter-spacing: -1.5px;">
                                                    <t t-esc="(state.metrics.charts and state.metrics.charts.realized_asset_value or 0).toLocaleString()"/> <small class="text-muted" style="font-size: 0.9rem; letter-spacing: 0;">AED</small>
                                                </h3>
                                                <div class="text-muted small mb-3 p-2 rounded" style="font-size: 0.75rem; background: rgba(0,0,0,0.03);">
                                                    <i class="fa fa-line-chart me-1 text-warning"></i> Potential Portfolio Value: <strong class="text-dark"><t t-esc="(state.metrics.charts and state.metrics.charts.potential_asset_value or 0).toLocaleString()"/></strong>
                                                </div>
                                                <div class="d-flex border-top pt-3 border-dark border-opacity-10 justify-content-between">
                                                    <div class="flex-grow-1">
                                                        <span class="text-success fw-bold d-block small uppercase" style="font-size: 0.6rem; letter-spacing: 0.5px;">Units Sold</span>
                                                        <span class="fs-5 fw-extrabold"><t t-esc="state.metrics.charts.sold_units or 0"/></span>
                                                    </div>
                                                    <div class="flex-grow-1 text-end border-start ps-3">
                                                        <span class="text-primary fw-bold d-block small uppercase" style="font-size: 0.6rem; letter-spacing: 0.5px;">Available</span>
                                                        <span class="fs-5 fw-extrabold"><t t-esc="state.metrics.charts.available_units or 0"/></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SUPPLY CHAIN RADAR -->
                        <div class="dashboard-sidebar-group">
                            <h6 class="sidebar-group-title">SUPPLY CHAIN RADAR</h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="metric-card metric-orange hover-lift cursor-pointer" t-on-click="openRequisitions">
                                        <i class="fa fa-shopping-cart card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.charts.procurement_risks.length or 0"/>
                                        <div class="card-label">Critical Risks</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="metric-card metric-teal hover-lift cursor-pointer" t-on-click="openContractors">
                                        <i class="fa fa-users card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.contractor_count or 0"/>
                                        <div class="card-label">Contractors</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- OPERATIONAL INTEGRITY -->
                        <div class="dashboard-sidebar-group">
                            <h6 class="sidebar-group-title">OPERATIONAL INTEGRITY</h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="metric-card metric-green hover-lift cursor-pointer" t-on-click="openInspections">
                                        <i class="fa fa-check-circle card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.inspection_count or 0"/>
                                        <div class="card-label">Inspections</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="metric-card metric-rose hover-lift cursor-pointer">
                                        <i class="fa fa-shield card-icon"></i>
                                        <div class="card-value">0</div>
                                        <div class="card-label">Safety</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- RESOURCE & TASK ALLOCATION -->
                        <div class="dashboard-sidebar-group">
                            <h6 class="sidebar-group-title">RESOURCE &amp; TASK ALLOCATION</h6>
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="metric-card metric-indigo hover-lift cursor-pointer" t-on-click="openJobOrders">
                                        <i class="fa fa-tasks card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.job_order_count or 0"/>
                                        <div class="card-label">Job Orders</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="metric-card metric-green hover-lift cursor-pointer" t-on-click="openMaterialRequests">
                                        <i class="fa fa-shopping-basket card-icon"></i>
                                        <div class="card-value" t-esc="state.metrics.material_request_count or 0"/>
                                        <div class="card-label">Mat Requests</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- PROCUREMENT ANALYSE -->
                        <div class="dashboard-sidebar-group">
                            <h6 class="sidebar-group-title">PROCUREMENT ANALYSE</h6>
                            <div class="col-12 cursor-pointer" t-on-click="openPurchase">
                                <div class="metric-card bg-primary text-white p-4 hover-lift" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
                                    <i class="fa fa-shopping-cart card-icon" style="opacity: 0.2; color: white;"></i>
                                    <div class="small fw-bold text-uppercase opacity-75 mb-2" style="font-size: 0.65rem; letter-spacing: 1px;">Total Commitment</div>
                                    <h3 class="fw-bolder m-0 text-white mb-3" style="font-size: 2rem; letter-spacing: -1px;">
                                        <t t-esc="(state.metrics.charts and state.metrics.charts.procurement_analysis and state.metrics.charts.procurement_analysis.total_value or 0).toLocaleString()"/>
                                        <small class="ms-1 opacity-75" style="font-size: 0.8rem;">AED</small>
                                    </h3>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="p-2 rounded bg-white bg-opacity-10 border border-white border-opacity-10">
                                                <div class="small opacity-75 uppercase" style="font-size: 0.55rem;">Draft</div>
                                                <div class="fw-bold"><t t-esc="state.metrics.charts and state.metrics.charts.procurement_analysis and state.metrics.charts.procurement_analysis.draft_count or 0"/></div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="p-2 rounded bg-white bg-opacity-10 border border-white border-opacity-10">
                                                <div class="small opacity-75 uppercase" style="font-size: 0.55rem;">Confirmed</div>
                                                <div class="fw-bold"><t t-esc="state.metrics.charts and state.metrics.charts.procurement_analysis and state.metrics.charts.procurement_analysis.confirmed_count or 0"/></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Dynamic Canvas -->
                    <div class="col-lg-9 dashboard-main-column p-4 pt-2">
                        
                        <!-- Secondary Financial Intelligence (Sales Trend) -->
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm overflow-hidden">
                                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5 class="fw-bold text-gray-800 m-0">Monthly Sales Analysis: Sold Performance</h5>
                                            <p class="text-muted small m-0">Revenue trend for completed Real Estate Transactions (Last 12 Months)</p>
                                        </div>
                                        <span class="badge bg-soft-primary text-primary"><i class="fa fa-line-chart"></i> Trend Active</span>
                                    </div>
                                    <div class="card-body p-4">
                                        <div style="height: 250px; width:100%;">
                                            <canvas id="yearlySalesChart"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Primary Charts Quadrant -->
                        <div class="row g-4 mb-4">
                            <!-- Category Burn Velocity (Grouped Bar) -->
                            <div class="col-lg-8">
                                <div class="card border-0 shadow-sm h-100 overflow-hidden">
                                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between">
                                        <h5 class="fw-bold text-gray-800">Financial Burn Analysis: Budget vs Actual</h5>
                                        <span class="badge bg-soft-success text-success">Real-time Sync</span>
                                    </div>
                                    <div class="card-body p-4">
                                        <div style="height: 320px; width:100%;">
                                            <canvas id="categoryBurnChart"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Contractor Pulse (Donut) -->
                            <div class="col-lg-4">
                                <div class="card border-0 shadow-sm h-100 overflow-hidden">
                                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                                        <h5 class="fw-bold text-gray-800">Contractor Site Pulse</h5>
                                    </div>
                                    <div class="card-body p-4">
                                        <div style="height: 250px; width:100%;">
                                            <canvas id="contractorPulseChart"></canvas>
                                        </div>
                                        <div class="mt-3 text-center small text-muted">
                                            <t t-esc="state.metrics.charts.contractor_pulse.active"/> Mobilized Units On-site
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Portfolio Lifecycle Analysis (Phase Distribution) -->
                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm overflow-hidden">
                                    <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                                        <div>
                                            <h5 class="fw-bold text-gray-800 m-0">Portfolio Lifecycle Pulse: Active Project Stages</h5>
                                            <p class="text-muted small m-0">Distribution of construction projects across operational phases</p>
                                        </div>
                                        <span class="badge bg-soft-info text-info"><i class="fa fa-refresh"></i> Lifecycle Live</span>
                                    </div>
                                    <div class="card-body p-4">
                                        <div style="height: 250px; width:100%;">
                                            <canvas id="projectPhaseChart"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actionable Radar Blocks -->
                        <div class="row g-4 mb-4">
                            <!-- Procurement Risk Radar Table -->
                            <div class="col-lg-7">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-white border-0 pt-4 pb-2 d-flex justify-content-between">
                                        <h5 class="fw-bold text-primary"><i class="fa fa-crosshairs"></i> Procurement Risk Radar</h5>
                                        <button class="btn btn-sm btn-outline-primary" t-on-click="openRequisitions">View All Risk Logs</button>
                                    </div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-hover align-middle mb-0">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th class="ps-4">Critical Material</th>
                                                        <th>Project Phase</th>
                                                        <th class="text-center">Severity</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="state.metrics.charts.procurement_risks" t-as="risk" t-key="risk.id">
                                                        <tr class="cursor-pointer">
                                                            <td class="ps-4 py-3">
                                                                 <div class="fw-bold text-dark"><t t-esc="risk.material"/></div>
                                                                 <div class="small text-muted"><t t-esc="risk.project"/></div>
                                                            </td>
                                                            <td><t t-esc="risk.phase"/></td>
                                                            <td class="text-center">
                                                                <t t-if="risk.severity == 'high'">
                                                                    <span class="badge rounded-pill bg-danger px-3">CRITICAL</span>
                                                                </t>
                                                                <t t-else="">
                                                                    <span class="badge rounded-pill bg-warning px-3">WARNING</span>
                                                                </t>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                    <t t-if="!state.metrics.charts.procurement_risks.length">
                                                        <tr><td colspan="3" class="text-center text-muted py-5">
                                                            <i class="fa fa-shield fa-2x mb-3 text-light"></i><br/>Supply chain signals stable. No urgent risks detected.
                                                        </td></tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Quality Gate Queue -->
                            <div class="col-lg-5">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-white border-0 pt-4 pb-2">
                                        <h5 class="fw-bold text-success"><i class="fa fa-clipboard-check"></i> Quality Verification Queue</h5>
                                    </div>
                                    <div class="card-body p-0 text-center">
                                        <div class="table-responsive" t-if="state.metrics.charts.pending_inspections.length">
                                            <table class="table table-hover align-middle mb-0 text-start">
                                                <tbody>
                                                    <t t-foreach="state.metrics.charts.pending_inspections" t-as="insp" t-key="insp.id">
                                                        <tr class="cursor-pointer">
                                                            <td class="ps-4 py-3">
                                                                <div class="fw-bold"><t t-esc="insp.name"/></div>
                                                                <div class="small text-success fw-bold"><t t-esc="insp.project"/></div>
                                                            </td>
                                                            <td class="pe-4 text-end">
                                                                <i class="fa fa-chevron-right text-light"></i>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                        <div t-else="" class="py-5">
                                            <i class="fa fa-certificate fa-3x text-light mb-3"></i>
                                            <div class="text-muted fw-bold">All inspections certified. quality standards met.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Site Intelligence Visuals (Project Albums) -->
                        <div class="row mt-4 mb-5">
                            <div class="col-12">
                                <div class="card border-0 shadow-sm p-4">
                                    <div class="d-flex align-items-center justify-content-between mb-4">
                                        <h5 class="fw-bold m-0"><i class="fa fa-camera-retro text-primary me-2"></i> Site Intelligence Visuals</h5>
                                        <span class="small text-muted">Real-time Field Updates</span>
                                    </div>
                                    <div class="photo-gallery-container d-flex overflow-auto pb-3 gap-3">
                                        <t t-if="state.metrics.recent_visuals">
                                            <t t-foreach="state.metrics.recent_visuals" t-as="album" t-key="album.id">
                                                <div class="photo-card cursor-pointer" t-on-click="() => this.openGallery(album)">
                                                    <div class="position-relative overflow-hidden" style="height: 180px; border-radius: 8px 8px 0 0; background: #f1f5f9;">
                                                        <img t-attf-src="/web/image?model=construction.project.image&amp;id=#{album.cover_image_id}&amp;field=image" class="photo-img w-100 h-100"/>
                                                        <div class="position-absolute top-0 end-0 m-2">
                                                            <span class="badge rounded-pill shadow-sm" style="background: rgba(15, 23, 42, 0.75); backdrop-filter: blur(4px); color: white; padding: 6px 12px; border: 1px solid rgba(255, 255, 255, 0.15); font-weight: 600;">
                                                                <i class="fa fa-image me-1"></i> <t t-esc="album.count"/> Photos
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="p-3 bg-white border-top">
                                                        <div class="fw-bold text-dark text-truncate" t-esc="album.name"/>
                                                        <div class="d-flex align-items-center text-muted small mt-1">
                                                            <i class="fa fa-calendar me-1"></i>
                                                            <span>Latest Progress View</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </t>
                                        <t t-if="!state.metrics.recent_visuals or !state.metrics.recent_visuals.length">
                                            <div class="text-center w-100 p-5 bg-white rounded border border-dashed">
                                                <i class="fa fa-image fa-3x mb-3 text-light"></i>
                                                <h5 class="text-muted">No site imagery documentation available.</h5>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Immersive Gallery Modal Overlay -->
                        <div t-if="state.active_album" class="gallery-modal-overlay" t-on-click.self="closeGallery">
                            <div class="gallery-modal-content p-4">
                                <div class="d-flex align-items-center justify-content-between mb-4 border-bottom border-white border-opacity-25 pb-3">
                                    <h4 class="text-white fw-bold m-0">
                                        <i class="fa fa-folder-open me-2 text-primary"></i> 
                                        <t t-esc="state.active_album.name"/> Progress Gallery
                                    </h4>
                                    <button class="btn btn-link text-white text-decoration-none" t-on-click="closeGallery">
                                        <i class="fa fa-times-circle fa-2x"></i>
                                    </button>
                                </div>
                                <div class="row g-4 overflow-auto" style="max-height: 70vh;">
                                    <t t-foreach="state.active_album.images" t-as="img" t-key="img.id">
                                        <div class="col-md-3">
                                            <div class="card border-0 shadow-sm overflow-hidden h-100 bg-secondary bg-opacity-10">
                                                <img t-attf-src="/web/image?model=construction.project.image&amp;id=#{img.id}&amp;field=image" class="img-fluid w-100" style="height: 200px; object-fit: cover;"/>
                                                <div class="p-2 bg-dark text-white text-center small">
                                                    <i class="fa fa-calendar me-1"></i> <t t-esc="img.date"/>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>
