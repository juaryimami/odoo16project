<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Job Order Graph -->
    <record id="view_construction_job_order_graph" model="ir.ui.view">
        <field name="name">construction.job.order.graph</field>
        <field name="model">construction.job.order</field>
        <field name="arch" type="xml">
            <graph string="Contractor Spend by Phase" type="bar">
                <field name="task_id" type="row"/>
                <field name="total_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Overdue Installments Window Action -->
    <record id="action_overdue_installments" model="ir.actions.act_window">
        <field name="name">Overdue Installments</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('installment_line_id', '!=', False),
            ('state', '=', 'posted'),
            ('payment_state', 'in', ['not_paid', 'partial']),
            ('invoice_date_due', '&lt;', context_today().strftime('%Y-%m-%d'))
        ]</field>
    </record>

    <record id="action_owl_construction_dashboard" model="ir.actions.client">
        <field name="name">Advanced Executive Dashboard</field>
        <field name="tag">construction_dashboard_client_action</field>
    </record>

    <record id="action_project_profitability_dashboard" model="ir.actions.client">
        <field name="name">Project Profitability Dashboard</field>
        <field name="tag">project_profitability_dashboard_action</field>
    </record>

    <!-- Menu items removed from here and moved to menu_views.xml for consolidation -->
</odoo>
