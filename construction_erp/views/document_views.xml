<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_construction_document_kanban" model="ir.ui.view">
        <field name="name">construction.document.kanban</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="project_id"/>
                <field name="document_type"/>
                <field name="upload_date"/>
                <field name="attachment_file"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12">
                                    <strong><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-8">
                                    <span class="badge text-bg-primary"><field name="document_type"/></span>
                                </div>
                                <div class="col-4 text-end">
                                    <field name="upload_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_construction_document_tree" model="ir.ui.view">
        <field name="name">construction.document.tree</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <tree string="Documents">
                <field name="name"/>
                <field name="project_id"/>
                <field name="document_type"/>
                <field name="upload_date"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_document_form" model="ir.ui.view">
        <field name="name">construction.document.form</field>
        <field name="model">construction.document</field>
        <field name="arch" type="xml">
            <form string="Document">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Document Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="document_type"/>
                        </group>
                        <group>
                            <field name="upload_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="attachment_file" filename="file_name" widget="binary"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="notes" placeholder="Detailed notes about this document..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_construction_document" model="ir.actions.act_window">
        <field name="name">Project Documents</field>
        <field name="res_model">construction.document</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_project_id': active_id, 'default_project_id': active_id}</field>
    </record>

</odoo>
