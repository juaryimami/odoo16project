<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_real_estate_installment_plan_tree" model="ir.ui.view">
        <field name="name">real.estate.installment.plan.tree</field>
        <field name="model">real_estate.installment.plan</field>
        <field name="arch" type="xml">
            <tree string="Installment Plans">
                <field name="name"/>
                <field name="client_id"/>
                <field name="unit_id"/>
                <field name="total_amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_real_estate_installment_plan_form" model="ir.ui.view">
        <field name="name">real.estate.installment.plan.form</field>
        <field name="model">real_estate.installment.plan</field>
        <field name="arch" type="xml">
            <form string="Installment Plan">
                <header>
                    <button name="action_generate_schedule" string="Generate Schedule" type="object" states="draft" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Plan / Contract Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="client_id"/>
                            <field name="unit_id"/>
                            <field name="total_amount"/>
                        </group>
                        <group>
                            <field name="deposit_amount"/>
                            <field name="number_of_months"/>
                            <field name="start_date"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Schedule Lines">
                            <field name="line_ids">
                                <tree editable="bottom" decoration-success="is_invoiced==True">
                                    <field name="name"/>
                                    <field name="due_date"/>
                                    <field name="amount"/>
                                    <field name="is_invoiced" readonly="1"/>
                                    <button name="action_create_invoice" string="Invoice" type="object" icon="fa-money" attrs="{'invisible': [('is_invoiced', '=', True)]}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_real_estate_installment_plan" model="ir.actions.act_window">
        <field name="name">Installment Plans</field>
        <field name="res_model">real_estate.installment.plan</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_real_estate_installment_plans"
              name="Installment Plans"
              parent="menu_construction_real_estate"
              action="action_real_estate_installment_plan"
              sequence="30"/>
</odoo>
