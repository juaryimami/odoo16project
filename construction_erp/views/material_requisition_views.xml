<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_requisition_tree" model="ir.ui.view">
        <field name="name">construction.material.requisition.tree</field>
        <field name="model">construction.material.requisition</field>
        <field name="arch" type="xml">
            <tree string="Material Requisitions">
                <field name="name"/>
                <field name="project_id"/>
                <field name="request_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_material_requisition_form" model="ir.ui.view">
        <field name="name">construction.material.requisition.form</field>
        <field name="model">construction.material.requisition</field>
        <field name="arch" type="xml">
            <form string="Material Requisition">
                <header>
                    <button name="action_approve_and_transfer" string="Approve &amp; Fulfill" type="object" class="oe_highlight" attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,partially_ordered,transferred"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_pickings" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="picking_count" widget="statinfo" string="Store Issues"/>
                        </button>
                        <button name="action_view_purchases" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="purchase_count" widget="statinfo" string="RFQs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Req Reference"/>
                        </h1>
                    </div>
                    <group>
                        <field name="project_id"/>
                        <field name="phase_id"/>
                        <field name="job_order_id"/>
                        <field name="request_date"/>
                        <field name="requested_by"/>
                    </group>
                    <notebook>
                        <page string="Requested Items">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_material_requisition" model="ir.actions.act_window">
        <field name="name">Material Requisitions</field>
        <field name="res_model">construction.material.requisition</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_material_requisition"
              name="Material Requisitions"
              parent="menu_construction_operations"
              action="action_material_requisition"
              sequence="40"/>
</odoo>
