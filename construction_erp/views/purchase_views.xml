<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_inherit_construction" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.construction</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="project_id" options="{'no_create': True}"/>
                <field name="lifecycle_id" invisible="1"/>
                <field name="construction_phase_id" options="{'no_create': True}" domain="[('lifecycle_id', '=', lifecycle_id)]" attrs="{'invisible': [('project_id', '=', False)]}"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="lifecycle_id" invisible="1"/>
                <field name="construction_phase_id" optional="show"/>
                <field name="cost_line_id" optional="show" domain="[('cost_sheet_id.project_id', '=', parent.project_id)]"/>
            </xpath>
        </field>
    </record>
</odoo>
