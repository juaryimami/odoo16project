<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_construction" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.construction</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_installment_plan" type="object" class="oe_stat_button" icon="fa-calendar" attrs="{'invisible': [('unit_id', '=', False)]}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Installment Plan</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="project_id" options="{'no_create': True}" placeholder="Select Construction Project"/>
                <field name="unit_id" options="{'no_create': True}" placeholder="Select Property Unit" attrs="{'invisible': [('project_id', '=', False)]}"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree//field[@name='name']" position="after">
                <field name="project_available_qty" attrs="{'column_invisible': [('parent.unit_id', '=', False)]}" decoration-bf="1" decoration-warning="project_available_qty &lt;= 5" decoration-danger="project_available_qty == 0"/>
            </xpath>
        </field>
    </record>

    <!-- Project-Side Units view: Add selling action -->
    <record id="action_sell_property_unit" model="ir.actions.server">
        <field name="name">Sell Unit</field>
        <field name="model_id" ref="construction_erp.model_real_estate_unit"/>
        <field name="binding_model_id" ref="construction_erp.model_real_estate_unit"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'name': 'Create Sale Quotation',
    'type': 'ir.actions.act_window',
    'res_model': 'sale.order',
    'view_mode': 'form',
    'context': {
        'default_project_id': record.project_id.id,
        'default_unit_id': record.id,
        'default_partner_id': record.client_id.id if record.client_id else False,
    }
}
        </field>
    </record>
</odoo>
