<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_material_requisition_confirmation_form" model="ir.ui.view">
        <field name="name">material.requisition.confirmation.form</field>
        <field name="model">material.requisition.confirmation</field>
        <field name="arch" type="xml">
            <form string="Confirm Material Delivery Split">
                <p class="oe_grey">
                    Some items in this requisition are not fully available in the project warehouse. 
                    Please confirm the quantities to <strong>Deliver Now</strong> (from stock) and <strong>Purchase</strong> (RFQ).
                </p>
                <field name="requisition_id" invisible="1"/>
                <field name="line_ids">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="product_id"/>
                        <field name="requested_qty"/>
                        <field name="available_qty" decoration-danger="available_qty &lt; requested_qty" decoration-success="available_qty &gt;= requested_qty"/>
                        <field name="deliver_qty"/>
                        <field name="purchase_qty"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm" string="Process Delivery &amp; RFQs" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
